@startuml SmartBalance Deployment
skinparam nodesep 80
skinparam ranksep 100

rectangle "Client Layer" <<#E3F2FD>> {
    component Browser
}

rectangle "Web Server Layer" <<#E8F5E9>> {
    component Nginx
}

rectangle "Application Layer" <<#F3E5F5>> {
    component Uvicorn
    component FastAPI

    rectangle BackendApp <<#FFF8E1>> {
        component APIRouters
        component CoreLB
        component MLModule
        component Simulation
    }
}

rectangle "Data Layer" <<#E0F7FA>> {
    database SQLite
}

rectangle "Container Layer" <<#ECEFF1>> {
    component DC
    component FastAPIContainer
    component ReactContainer
    component NginxContainer
}

Browser --> Nginx
Nginx --> Uvicorn
Uvicorn --> FastAPI
FastAPI --> APIRouters
FastAPI --> CoreLB
FastAPI --> MLModule
FastAPI --> Simulation

FastAPI --> SQLite

Browser - FastAPI : WebSocket

DC --> FastAPIContainer
DC --> ReactContainer
DC --> NginxContainer
@enduml