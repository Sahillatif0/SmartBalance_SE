@startuml SmartBalance Architecture
skinparam componentStyle rectangle

package Frontend <<#E3F2FD>> {
    component App
    component Dashboard
    component ServerList
    component MetricsChart
    component TrafficSimulator
    component AlgorithmSelector
    component ForecastOverlay
    component RoutingLog
    component useWebSocket
    component api
}

package Backend <<#E8F5E9>> {
    component FastAPI

    package Routers <<#FFF3E0>> {
        component servers
        component algorithms
        component metrics
        component simulation
    }

    package CoreLB <<#F3E5F5>> {
        component LoadBalancer
        component RoundRobinLB
        component LeastConnectionsLB
        component WeightedRoundRobinLB
        component SmartRouter
        component AlgorithmRegistry
    }

    package ML <<#E0F7FA>> {
        component LSTMModel
        component TrafficPredictor
        component MetricsCalculator
    }

    package Simulation <<#FFF8E1>> {
        component TrafficGenerator
        component HealthChecker
        component ServerPool
        component EventBus
    }

    package Services <<#ECEFF1>> {
        component WebSocketManager
        component Database
    }
}

Dashboard --> ServerList
Dashboard --> MetricsChart
Dashboard --> TrafficSimulator
Dashboard --> AlgorithmSelector
Dashboard --> ForecastOverlay
Dashboard --> RoutingLog
Dashboard --> useWebSocket
useWebSocket --> api

api --> FastAPI
FastAPI --> servers
FastAPI --> algorithms
FastAPI --> metrics
FastAPI --> simulation

algorithms --> AlgorithmRegistry
AlgorithmRegistry --> RoundRobinLB
AlgorithmRegistry --> LeastConnectionsLB
AlgorithmRegistry --> WeightedRoundRobinLB

SmartRouter --> AlgorithmRegistry
SmartRouter --> TrafficPredictor

simulation --> TrafficGenerator
simulation --> HealthChecker

TrafficGenerator --> LSTMModel
TrafficPredictor --> LSTMModel

FastAPI --> WebSocketManager
FastAPI --> Database

LoadBalancer <|-- RoundRobinLB
LoadBalancer <|-- LeastConnectionsLB
LoadBalancer <|-- WeightedRoundRobinLB
LoadBalancer <|-- SmartRouter
@enduml