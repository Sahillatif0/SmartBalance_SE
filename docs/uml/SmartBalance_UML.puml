@startuml SmartBalance_State_Diagram
!theme plain

title SmartBalance - Server Health State Machine

state ServerLifecycle {
  [*] --> Healthy
  Healthy --> Degraded : Single Health Check Failure
  Degraded --> Healthy : Health Check Success
  Degraded --> Unhealthy : 3 Consecutive Failures
  Unhealthy --> Degraded : Manual Recovery / Graceful Restart
  Unhealthy --> Healthy : Automatic Recovery After Timeout
  Healthy --> [*] : Removed from Pool
  Unhealthy --> [*] : Removed from Pool
}

state AlgorithmSelection {
  [*] --> RoundRobin

  state RoundRobin {
    state "Normal Traffic" as RR1
    state "Under Load" as RR2
  }

  RoundRobin --> LeastConnections : Predicted Load > 150%
  LeastConnections --> RoundRobin : Load Returns to Normal

  state LeastConnections {
    state "Burst Traffic" as LC1
    state "Balancing" as LC2
  }

  LC1 --> LC2 : Traffic Stabilizes
  LC2 --> LC1 : New Burst Detected
}

[*] --> Active
Active --> AlgorithmSelection
AlgorithmSelection -right-> [*]

note right of RoundRobin
  O(1) Circular Selection
  Default Algorithm
end note

note right of LeastConnections
  O(log n) Min-Heap
  Optimal for Burst Traffic
end note

@enduml

