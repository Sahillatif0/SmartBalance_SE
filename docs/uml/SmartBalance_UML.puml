@startuml SmartBalance_Class_Diagram
!theme plain

title SmartBalance - Core Class Diagram

class Server {
  +id: str
  +host: str
  +port: int
  +weight: int = 1
  +connections: int = 0
  +healthy: bool = True
  +failure_count: int = 0
  +last_health_check: datetime
  --
  +increment_connections()
  +decrement_connections()
  +mark_unhealthy()
  +mark_healthy()
}

abstract class LoadBalancer {
  +name: str {abstract}
  +description: str {abstract}
  +complexity: str {abstract}
  --
  +select_server(servers: List[Server]): Server {abstract}
  +filter_healthy(servers): List[Server]
  +get_least_busy_server(servers): Server
}

class RoundRobinLB {
  -current_index: int
  --
  +select_server(servers): Server
  +name: str = "Round Robin"
  +description: str = "O(1) circular distribution"
  +complexity: str = "O(1)"
}

class LeastConnectionsLB {
  -connection_heap: List[Tuple[int, str]]
  --
  +select_server(servers): Server
  +name: str = "Least Connections"
  +description: str = "Min-heap based selection"
  +complexity: str = "O(log n)"
}

class WeightedRoundRobinLB {
  -current_weights: Dict[str, int]
  -cycle_complete: bool
  --
  +select_server(servers): Server
  +name: str = "Weighted Round Robin"
  +description: str = "Weight-based cycling"
  +complexity: str = "O(n)"
}

class SmartRouter {
  -inner_algorithm: LoadBalancer
  -prediction_threshold: float = 1.5
  -mape_target: float = 15.0
  -traffic_predictor: TrafficPredictor
  --
  +select_server(servers): Server
  +update_predictions(traffic_rates)
  +should_switch_algorithm(prediction): bool
  +name: str = "Smart Router"
  +description: str = "AI-driven algorithm switching"
  +complexity: str = "O(n)"
}

class LSTMModel {
  -lstm: nn.LSTM
  -fc: Sequential
  -hidden_size: int = 64
  -num_layers: int = 2
  -output_steps: int = 15
  --
  +forward(x): Tensor
}

class TrafficPredictor {
  -window_size: int = 60
  -forecast_steps: int = 15
  -model: LSTMModel
  -trajectory: List[float]
  -is_trained: bool
  --
  +add_traffic_sample(rate: float)
  +predict(): List[float]
  +get_mape(actual, predicted): float
  +train_model(X, y, epochs)
}

class RoutingService {
  -servers: List[Server]
  -load_balancer: LoadBalancer
  -predictor: TrafficPredictor
  -ws_manager: WebSocketManager
  --
  +register_server(server)
  +remove_server(server_id)
  +route_request(): RoutingResult
  +switch_algorithm(name)
  +get_metrics()
}

LoadBalancer <|-- RoundRobinLB
LoadBalancer <|-- LeastConnectionsLB
LoadBalancer <|-- WeightedRoundRobinLB
LoadBalancer <|-- SmartRouter

SmartRouter o-- LoadBalancer
SmartRouter o-- TrafficPredictor
TrafficPredictor o-- LSTMModel
RoutingService o-- LoadBalancer
RoutingService o-- Server
RoutingService o-- TrafficPredictor

@enduml

@startuml SmartBalance_Sequence_Diagram
!theme plain

title SmartBalance - Request Routing Flow

actor Client
participant "Frontend\nDashboard" as FE
participant "WebSocket" as WS
participant "RoutingService" as Routing
participant "LoadBalancer" as LB
participant "SmartRouter" as SR
participant "LSTM\nPredictor" as Predictor
participant "Backend\nServer" as Backend

== Normal Request Flow ==

Client -> FE: HTTP Request
FE -> WS: Route Request
WS -> Routing: route_request()
Routing -> LB: select_server(servers)
LB -> Backend: Select Server
Backend --> LB: Selected Server
LB --> Routing: RoutingResult
Routing -> WS: Broadcast Update
WS --> FE: Server Update
FE --> Client: Response

== Smart Router Auto-Switch ==

Routing -> Predictor: predict_next()
Predictor -> Predictor: Generate 15-step forecast
Predictor --> Routing: predictions[]

alt Predicted Load > 150% Capacity
    Routing -> Routing: switch_algorithm("least_connections")
    Routing -> LB: Update Algorithm
    Routing -> WS: Broadcast Algorithm Change
end

== Traffic Simulation ==

actor Operator
Operator -> FE: Configure Simulation
FE -> WS: /simulation/config
WS -> Routing: Update Config
Routing -> TrafficGenerator: Apply Profile
TrafficGenerator -> Routing: Generate Traffic
note right
  Profiles:
  - steady: Constant rate
  - burst: High spikes
  - ramp: Gradual increase
  - wave: Sinusoidal pattern
end note

== Health Check ==

loop Every 5 seconds
    HealthChecker -> Backend: Health Check
    alt 3 Consecutive Failures
        HealthChecker -> Server: mark_unhealthy()
        HealthChecker -> WS: Broadcast Health Update
    else Server Responds
        HealthChecker -> Server: mark_healthy()
    end
end

@enduml

