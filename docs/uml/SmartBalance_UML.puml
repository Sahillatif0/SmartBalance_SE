@startuml SmartBalance_Data_Model
!theme plain

title SmartBalance - Data Models

class Server {
  id: string (PK)
  host: string
  port: integer
  weight: integer
  connections: integer
  healthy: boolean
  failure_count: integer
  created_at: datetime
  updated_at: datetime
}

class Metric {
  id: integer (PK)
  server_id: string (FK)
  timestamp: datetime
  latency: float
  error_rate: float
  throughput: float
}

class RoutingDecision {
  id: integer (PK)
  algorithm: string
  selected_server_id: string
  request_count: integer
  timestamp: datetime
  extra_data: JSON
}

class SimulationConfig {
  profile: enum(steady|burst|ramp|wave)
  rate: float
  duration: float
  start_time: datetime
}

class Prediction {
  predictions: float[]
  timestamps: datetime[]
  confidence: float
  model_version: string
}

Server "1" --> "many" Metric
Server "1" --> "many" RoutingDecision

