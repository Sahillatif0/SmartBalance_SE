@startuml SmartBalance_System_Architecture
!theme plain

title SmartBalance - AI-Driven Load Balancer System Architecture

package "Frontend (React/Vite)" {
  [Dashboard.tsx] as Dashboard
  [ServerList.tsx] as ServerList
  [MetricsChart.tsx] as MetricsChart
  [TrafficSimulator.tsx] as TrafficSimulator
  [useWebSocket.ts] as WebSocketHook
  [useMetrics.ts] as MetricsHook
  [types/index.ts] as FrontendTypes
}

package "Backend (FastAPI/Python)" {
  package "Core - Load Balancing" {
    [LoadBalancer.abstract] as LB_Abstract
    [RoundRobinLB] as RR_LB
    [LeastConnectionsLB] as LC_LB
    [WeightedRoundRobinLB] as WRR_LB
    [SmartRouter] as Smart_Router
    [Server.dataclass] as Server
  }

  package "ML - LSTM Prediction" {
    [LSTMModel] as LSTM
    [TrafficPredictor] as Predictor
    [metrics_calculator] as MetricsCalc
  }

  package "Simulation Engine" {
    [TrafficGenerator] as TrafficGen
    [HealthChecker] as HealthCheck
    [FaultInjector] as FaultInject
  }

  package "Services" {
    [RoutingService] as RoutingSvc
    [WebSocketManager] as WSManager
  }

  package "API Routers" {
    [servers_router] as ServersAPI
    [algorithms_router] as AlgosAPI
    [simulation_router] as SimAPI
    [metrics_router] as MetricsAPI
  }

  package "Data Layer" {
    [Server.model] as ServerModel
    [Metric.model] as MetricModel
    [RoutingDecision.model] as RoutingModel
    [schemas.py] as Schemas
  }
}

package "Database" {
  database "SQLite" as DB
}

